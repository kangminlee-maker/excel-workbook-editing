{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://day1company.local/spreadsheet-processing/apply-result.schema.json",
  "title": "Spreadsheet Processing Apply Result",
  "type": "object",
  "required": [
    "schema_version",
    "snapshot_id",
    "captured_at",
    "operation",
    "spreadsheet_id",
    "requested_ranges",
    "value_input_option",
    "write_count",
    "updated_cells",
    "updated_rows",
    "updated_columns",
    "before",
    "after",
    "rollback",
    "artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0" },
    "snapshot_id": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "format": "date-time" },
    "operation": {
      "type": "string",
      "enum": ["apply.values_update", "rollback.values_restore"]
    },
    "spreadsheet_id": { "type": "string", "minLength": 1 },
    "requested_ranges": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "value_input_option": { "const": "USER_ENTERED" },
    "write_count": { "type": "integer", "minimum": 1 },
    "updated_cells": { "type": "integer", "minimum": 0 },
    "updated_rows": { "type": "integer", "minimum": 0 },
    "updated_columns": { "type": "integer", "minimum": 0 },
    "before": {
      "type": "array",
      "items": { "$ref": "#/$defs/value_range" }
    },
    "after": {
      "type": "array",
      "items": { "$ref": "#/$defs/value_range" }
    },
    "rollback": { "$ref": "#/$defs/rollback" },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    }
  },
  "$defs": {
    "value_range": {
      "type": "object",
      "required": ["range", "major_dimension", "values", "row_count", "column_count"],
      "additionalProperties": false,
      "properties": {
        "range": { "type": "string" },
        "major_dimension": { "type": "string" },
        "values": { "type": "array", "items": { "type": "array" } },
        "row_count": { "type": "integer", "minimum": 0 },
        "column_count": { "type": "integer", "minimum": 0 }
      }
    },
    "rollback": {
      "type": "object",
      "required": [
        "operation",
        "spreadsheet_id",
        "ranges",
        "write_requests",
        "rollback_of_request_id"
      ],
      "additionalProperties": false,
      "properties": {
        "operation": { "const": "rollback.values_restore" },
        "spreadsheet_id": { "type": "string", "minLength": 1 },
        "ranges": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "write_requests": {
          "type": "array",
          "items": { "$ref": "#/$defs/write_request" }
        },
        "rollback_of_request_id": { "type": "string" }
      }
    },
    "write_request": {
      "type": "object",
      "required": ["range", "values"],
      "additionalProperties": false,
      "properties": {
        "range": { "type": "string", "minLength": 1 },
        "values": { "type": "array", "items": { "type": "array" } }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["kind", "summary"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string" },
        "summary": { "type": ["object", "null"] }
      }
    }
  }
}
