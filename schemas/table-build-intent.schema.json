{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://day1company.local/spreadsheet-processing/table-build-intent.schema.json",
  "title": "TableBuildIntent",
  "type": "object",
  "required": [
    "schema_version",
    "intent_kind",
    "intent_id",
    "created_at",
    "source",
    "source_package",
    "artifact_type",
    "output_canvas",
    "llm_prompt",
    "output",
    "review_state"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0" },
    "intent_kind": { "const": "table_build_intent_v1" },
    "intent_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "source": { "type": "object" },
    "source_package": { "type": "object" },
    "artifact_type": { "type": "string", "enum": ["google_sheets", "excel_workbook"] },
    "output_canvas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      }
    },
    "llm_prompt": { "type": "string", "minLength": 1 },
    "source_hints": { "type": "object" },
    "fields": { "type": "object" },
    "formula": { "type": "object" },
    "output": {
      "type": "object",
      "required": ["creation_mode"],
      "properties": {
        "creation_mode": { "type": "string", "enum": ["sheet", "copy"] },
        "preferred_title": { "type": "string" },
        "sheet_title": { "type": "string" },
        "title": { "type": "string" },
        "workbook_path": { "type": "string" },
        "copy_title": { "type": "string" },
        "format": { "type": "object" }
      },
      "additionalProperties": true
    },
    "review_state": {
      "type": "object",
      "required": ["status", "next_action"],
      "additionalProperties": true,
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string", "minLength": 1 }
      }
    }
  }
}
