{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/workbook-llm-proposal-validation.schema.json",
  "title": "Workbook LLM Proposal Validation",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source_artifacts",
    "method",
    "validation_context",
    "proposal_results",
    "review_queue",
    "summary",
    "gate_summary",
    "parser_observations"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "source_artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "method": {
      "type": "object",
      "required": ["name", "authority", "decision_policy"],
      "properties": {
        "name": {
          "type": "string"
        },
        "authority": {
          "const": "proposal_gate_outcome_not_final_graph_assembly"
        },
        "decision_policy": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "validation_context": {
      "type": "object",
      "required": [
        "proposal_summary",
        "semantic_readiness",
        "known_evidence_ref_count",
        "known_data_view_count",
        "known_pipeline_count",
        "local_boundary_statuses"
      ],
      "properties": {
        "proposal_summary": {
          "type": "object"
        },
        "semantic_readiness": {
          "type": "object"
        },
        "known_evidence_ref_count": {
          "type": "integer",
          "minimum": 0
        },
        "known_data_view_count": {
          "type": "integer",
          "minimum": 0
        },
        "known_pipeline_count": {
          "type": "integer",
          "minimum": 0
        },
        "local_boundary_statuses": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "null"]
          }
        }
      },
      "additionalProperties": true
    },
    "proposal_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proposalResult"
      }
    },
    "review_queue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewItem"
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "proposal_result_count",
        "accepted_count",
        "warning_count",
        "requires_human_review_count",
        "quarantined_count",
        "rejected_count",
        "semantic_concept_result_count",
        "hierarchy_result_count",
        "semantic_relation_result_count",
        "alias_result_count",
        "ambiguity_note_result_count",
        "validation_status"
      ],
      "properties": {
        "proposal_result_count": {
          "type": "integer",
          "minimum": 0
        },
        "accepted_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_count": {
          "type": "integer",
          "minimum": 0
        },
        "requires_human_review_count": {
          "type": "integer",
          "minimum": 0
        },
        "quarantined_count": {
          "type": "integer",
          "minimum": 0
        },
        "rejected_count": {
          "type": "integer",
          "minimum": 0
        },
        "semantic_concept_result_count": {
          "type": "integer",
          "minimum": 0
        },
        "hierarchy_result_count": {
          "type": "integer",
          "minimum": 0
        },
        "semantic_relation_result_count": {
          "type": "integer",
          "minimum": 0
        },
        "alias_result_count": {
          "type": "integer",
          "minimum": 0
        },
        "ambiguity_note_result_count": {
          "type": "integer",
          "minimum": 0
        },
        "validation_status": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "gate_summary": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "parser_observations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/observation"
      }
    }
  },
  "$defs": {
    "proposalResult": {
      "type": "object",
      "required": [
        "id",
        "proposal_id",
        "proposal_type",
        "final_status",
        "gate_results",
        "blocking_gates",
        "warning_gates",
        "evidence_refs"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "proposal_id": {
          "type": "string"
        },
        "proposal_type": {
          "type": "string"
        },
        "final_status": {
          "enum": [
            "accepted",
            "warning",
            "requires_human_review",
            "quarantined",
            "rejected"
          ]
        },
        "label": {
          "type": ["string", "null"]
        },
        "gate_results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gateResult"
          }
        },
        "blocking_gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warning_gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "gateResult": {
      "type": "object",
      "required": ["gate", "status", "reason", "evidence_refs"],
      "properties": {
        "gate": {
          "type": "string"
        },
        "status": {
          "enum": [
            "accepted",
            "warning",
            "requires_human_review",
            "quarantined",
            "rejected"
          ]
        },
        "reason": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "reviewItem": {
      "type": "object",
      "required": [
        "id",
        "proposal_id",
        "proposal_type",
        "status",
        "blocking_gates",
        "required_action"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "proposal_id": {
          "type": "string"
        },
        "proposal_type": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "label": {
          "type": ["string", "null"]
        },
        "blocking_gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_action": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "observation": {
      "type": "object",
      "required": ["level", "message"],
      "properties": {
        "level": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
