{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://day1company.local/excel-workbook-editing/workbook-table-io-pipeline.schema.json",
  "title": "Workbook Table I/O Pipelines",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source_artifacts",
    "pipelines",
    "summary",
    "parser_observations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "0.1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_artifacts": { "$ref": "#/$defs/source_artifacts" },
    "pipelines": {
      "type": "array",
      "items": { "$ref": "#/$defs/pipeline" }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "parser_observations": {
      "type": "array",
      "items": { "$ref": "#/$defs/observation" }
    }
  },
  "$defs": {
    "source_artifacts": {
      "type": "object",
      "required": ["block_candidates"],
      "additionalProperties": false,
      "properties": {
        "block_candidates": { "type": "string", "minLength": 1 }
      }
    },
    "pipeline": {
      "type": "object",
      "required": [
        "id",
        "type",
        "status",
        "role",
        "output_ref",
        "input_refs",
        "transform_refs",
        "evidence_refs",
        "confidence",
        "review_flags"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "table_io_pipeline" },
        "status": { "const": "candidate" },
        "role": {
          "type": "string",
          "enum": [
            "unknown",
            "input",
            "parameter",
            "bridge",
            "transform",
            "summary",
            "report",
            "audit_check"
          ]
        },
        "output_ref": { "$ref": "#/$defs/pipeline_ref" },
        "input_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/pipeline_ref" }
        },
        "transform_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/transform_ref" }
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "review_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "unresolved_input_region",
              "external_workbook_dependency",
              "pivot_cache_dependency",
              "same_sheet_dataflow",
              "repeated_formula_family"
            ]
          }
        }
      }
    },
    "pipeline_ref": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "workbook",
        "sheet",
        "range",
        "block_id",
        "region_id",
        "bounds",
        "label"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "cell_region",
            "row_band",
            "pivot_table",
            "workbook_range",
            "external_workbook_range",
            "pivot_cache_source_range",
            "unresolved_block"
          ]
        },
        "workbook": { "type": ["string", "null"] },
        "sheet": { "type": ["string", "null"] },
        "range": { "type": ["string", "null"] },
        "block_id": { "type": ["string", "null"] },
        "region_id": { "type": ["string", "null"] },
        "bounds": {
          "anyOf": [
            { "$ref": "#/$defs/dimension_bounds" },
            { "type": "null" }
          ]
        },
        "label": { "type": ["string", "null"] }
      }
    },
    "transform_ref": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "relation_group_id",
        "relation_id",
        "relation_type",
        "formula_signature",
        "formula_cell_count",
        "reference_count",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["formula_signature_group", "pivot_cache"]
        },
        "relation_group_id": { "type": ["string", "null"] },
        "relation_id": { "type": ["string", "null"] },
        "relation_type": { "type": "string" },
        "formula_signature": { "type": ["string", "null"] },
        "formula_cell_count": { "type": "integer", "minimum": 0 },
        "reference_count": { "type": "integer", "minimum": 0 },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "formula_signature_group",
              "pivot_function",
              "external_workbook",
              "pivot_cache_source"
            ]
          }
        }
      }
    },
    "dimension_bounds": {
      "type": "object",
      "required": ["min_row", "min_column", "max_row", "max_column"],
      "additionalProperties": false,
      "properties": {
        "min_row": { "type": "integer", "minimum": 1 },
        "min_column": { "type": "integer", "minimum": 1 },
        "max_row": { "type": "integer", "minimum": 1 },
        "max_column": { "type": "integer", "minimum": 1 }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "pipeline_count",
        "formula_pipeline_count",
        "pivot_pipeline_count",
        "external_dependency_pipeline_count",
        "unresolved_input_pipeline_count",
        "summary_role_count",
        "bridge_role_count",
        "report_role_count"
      ],
      "additionalProperties": false,
      "properties": {
        "pipeline_count": { "type": "integer", "minimum": 0 },
        "formula_pipeline_count": { "type": "integer", "minimum": 0 },
        "pivot_pipeline_count": { "type": "integer", "minimum": 0 },
        "external_dependency_pipeline_count": { "type": "integer", "minimum": 0 },
        "unresolved_input_pipeline_count": { "type": "integer", "minimum": 0 },
        "summary_role_count": { "type": "integer", "minimum": 0 },
        "bridge_role_count": { "type": "integer", "minimum": 0 },
        "report_role_count": { "type": "integer", "minimum": 0 }
      }
    },
    "observation": {
      "type": "object",
      "required": ["level", "message"],
      "additionalProperties": false,
      "properties": {
        "level": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string" }
      }
    }
  }
}
