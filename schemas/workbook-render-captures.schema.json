{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://day1company.local/excel-workbook-editing/workbook-render-captures.schema.json",
  "title": "Workbook Render Captures",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source_artifacts",
    "source_workbook",
    "method",
    "selected_target_ids",
    "captures",
    "gate_results",
    "summary",
    "parser_observations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "0.1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source_artifacts": { "$ref": "#/$defs/source_artifacts" },
    "source_workbook": { "$ref": "#/$defs/source_workbook" },
    "method": { "$ref": "#/$defs/method" },
    "selected_target_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "captures": {
      "type": "array",
      "items": { "$ref": "#/$defs/capture" }
    },
    "gate_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate_result" }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "parser_observations": {
      "type": "array",
      "items": { "$ref": "#/$defs/observation" }
    }
  },
  "$defs": {
    "source_artifacts": {
      "type": "object",
      "required": ["cross_validation_plan"],
      "additionalProperties": false,
      "properties": {
        "cross_validation_plan": { "type": "string", "minLength": 1 }
      }
    },
    "source_workbook": {
      "type": "object",
      "required": ["path", "file_name", "size_bytes", "sha256"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "file_name": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "method": {
      "type": "object",
      "required": [
        "engine",
        "capture_method",
        "helper",
        "sandbox_copy",
        "png_export_settings"
      ],
      "additionalProperties": false,
      "properties": {
        "engine": { "const": "Microsoft Excel" },
        "capture_method": { "const": "range_copy_picture_png" },
        "helper": { "type": "string", "minLength": 1 },
        "sandbox_copy": { "type": "boolean" },
        "png_export_settings": {
          "type": "object",
          "required": ["appearance", "format"],
          "additionalProperties": false,
          "properties": {
            "appearance": { "const": "screen" },
            "format": { "const": "picture" }
          }
        }
      }
    },
    "capture": {
      "type": "object",
      "required": [
        "id",
        "type",
        "status",
        "target_id",
        "sheet",
        "requested_range",
        "capture_window",
        "target_ref",
        "output",
        "coordinate_map",
        "gate_results",
        "parser_observations"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "render_capture" },
        "status": { "type": "string", "enum": ["captured", "capture_failed"] },
        "target_id": { "type": "string", "minLength": 1 },
        "sheet": { "type": ["string", "null"] },
        "requested_range": { "type": ["string", "null"] },
        "capture_window": {
          "type": "object",
          "additionalProperties": true
        },
        "target_ref": {
          "type": "object",
          "additionalProperties": true
        },
        "output": { "$ref": "#/$defs/capture_output" },
        "coordinate_map": { "$ref": "#/$defs/coordinate_map" },
        "gate_results": {
          "type": "array",
          "items": { "$ref": "#/$defs/gate_result" }
        },
        "parser_observations": {
          "type": "array",
          "items": { "$ref": "#/$defs/observation" }
        }
      }
    },
    "capture_output": {
      "type": "object",
      "required": [
        "pdf_path",
        "png_path",
        "pdf_size_bytes",
        "png_size_bytes",
        "png_width",
        "png_height"
      ],
      "additionalProperties": false,
      "properties": {
        "pdf_path": { "type": ["string", "null"] },
        "png_path": { "type": "string" },
        "pdf_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "png_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "png_width": { "type": ["integer", "null"], "minimum": 1 },
        "png_height": { "type": ["integer", "null"], "minimum": 1 }
      }
    },
    "coordinate_map": {
      "type": "object",
      "required": ["status", "cell_range", "capture_bbox"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["range_image_only", "not_available"] },
        "cell_range": { "type": ["string", "null"] },
        "capture_bbox": {
          "anyOf": [
            { "$ref": "#/$defs/capture_bbox" },
            { "type": "null" }
          ]
        }
      }
    },
    "capture_bbox": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "gate_result": {
      "type": "object",
      "required": [
        "id",
        "type",
        "capture_id",
        "target_id",
        "gate_check_id",
        "gate_type",
        "status",
        "evidence_refs",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "visual_formula_gate_result" },
        "capture_id": { "type": "string", "minLength": 1 },
        "target_id": { "type": "string", "minLength": 1 },
        "gate_check_id": { "type": ["string", "null"] },
        "gate_type": { "type": ["string", "null"] },
        "status": {
          "type": "string",
          "enum": ["captured_pending_review", "capture_failed"]
        },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "selected_target_count",
        "captured_count",
        "failed_count",
        "png_count",
        "gate_result_count",
        "captured_pending_review_gate_count",
        "capture_failed_gate_count"
      ],
      "additionalProperties": false,
      "properties": {
        "selected_target_count": { "type": "integer", "minimum": 0 },
        "captured_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "png_count": { "type": "integer", "minimum": 0 },
        "gate_result_count": { "type": "integer", "minimum": 0 },
        "captured_pending_review_gate_count": { "type": "integer", "minimum": 0 },
        "capture_failed_gate_count": { "type": "integer", "minimum": 0 }
      }
    },
    "observation": {
      "type": "object",
      "required": ["level", "message"],
      "additionalProperties": false,
      "properties": {
        "level": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string" }
      }
    }
  }
}
