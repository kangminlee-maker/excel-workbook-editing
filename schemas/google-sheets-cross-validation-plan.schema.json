{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://day1company.local/excel-workbook-editing/google-sheets-cross-validation-plan.schema.json",
  "title": "Google Sheets Cross-Validation Plan",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "authority",
    "validation_targets",
    "deterministic_gates",
    "source_evidence_read_plan",
    "summary",
    "parser_observations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "0.1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source": { "$ref": "#/$defs/source" },
    "authority": { "$ref": "#/$defs/authority" },
    "validation_targets": { "type": "array", "items": { "$ref": "#/$defs/validation_target" } },
    "deterministic_gates": { "type": "array", "items": { "$ref": "#/$defs/gate" } },
    "source_evidence_read_plan": { "$ref": "#/$defs/source_evidence_read_plan" },
    "summary": { "$ref": "#/$defs/counts" },
    "parser_observations": { "type": "array", "items": { "$ref": "#/$defs/observation" } }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["spreadsheet_id", "spreadsheet_url", "title", "source_artifacts"],
      "additionalProperties": false,
      "properties": {
        "spreadsheet_id": { "type": "string", "minLength": 1 },
        "spreadsheet_url": { "type": ["string", "null"] },
        "title": { "type": "string" },
        "source_artifacts": {
          "type": "object",
          "required": ["live_table_io_pipelines", "live_block_candidate_tuning"],
          "additionalProperties": false,
          "properties": {
            "live_table_io_pipelines": { "type": "string", "minLength": 1 },
            "live_block_candidate_tuning": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "source_document",
        "plan_status",
        "formula_result_authority",
        "source_spreadsheet_read_authority",
        "allowed_evidence_scope"
      ],
      "additionalProperties": false,
      "properties": {
        "source_document": { "const": "connected_google_sheet_evidence" },
        "plan_status": { "const": "validation_plan_only_no_live_read" },
        "formula_result_authority": { "const": "not_established" },
        "source_spreadsheet_read_authority": { "const": "blocked_until_source_access_evidence" },
        "allowed_evidence_scope": { "const": "bounded_source_evidence_only" }
      }
    },
    "validation_target": {
      "type": "object",
      "required": [
        "id",
        "type",
        "target_type",
        "status",
        "priority",
        "sheet",
        "range",
        "related_pipeline_ids",
        "evidence_refs",
        "authority_blockers",
        "planned_gates",
        "next_action"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "google_sheets_cross_validation_target" },
        "target_type": {
          "type": "string",
          "enum": [
            "pipeline_flow",
            "external_source_authority",
            "formula_error_surface",
            "remaining_bounded_sampling"
          ]
        },
        "status": { "type": "string", "enum": ["candidate", "blocked"] },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "sheet": { "type": ["string", "null"] },
        "range": { "type": ["string", "null"] },
        "related_pipeline_ids": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "authority_blockers": { "type": "array", "items": { "type": "string" } },
        "planned_gates": { "type": "array", "items": { "$ref": "#/$defs/gate" } },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "gate": {
      "type": "object",
      "required": [
        "id",
        "type",
        "target_id",
        "gate_type",
        "status",
        "deterministic_inputs",
        "pass_conditions",
        "failure_signals"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "const": "deterministic_validation_gate" },
        "target_id": { "type": "string", "minLength": 1 },
        "gate_type": {
          "type": "string",
          "enum": [
            "formula_text_dependency_trace",
            "bounded_sample_surface_trace",
            "formula_error_reconciliation",
            "external_source_authority",
            "bounded_read_policy_check"
          ]
        },
        "status": { "type": "string", "enum": ["planned", "blocked"] },
        "deterministic_inputs": { "type": "array", "items": { "type": "string" } },
        "pass_conditions": { "type": "array", "items": { "type": "string" } },
        "failure_signals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "source_evidence_read_plan": {
      "type": "object",
      "required": [
        "status",
        "max_ranges_per_operation",
        "batches",
        "blocked_source_reads",
        "unauthorized_source_read_count"
      ],
      "additionalProperties": false,
      "properties": {
        "status": { "const": "planned_not_executed" },
        "max_ranges_per_operation": { "type": "integer", "minimum": 1 },
        "batches": { "type": "array", "items": { "$ref": "#/$defs/source_evidence_batch" } },
        "blocked_source_reads": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "unauthorized_source_read_count": { "type": "integer", "minimum": 0 }
      }
    },
    "source_evidence_batch": {
      "type": "object",
      "required": ["id", "operation", "ranges", "read_candidate_ids", "status", "authority"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "operation": { "type": "string", "minLength": 1 },
        "ranges": { "type": "array", "items": { "type": "string" } },
        "read_candidate_ids": { "type": "array", "items": { "type": "string" } },
        "status": { "const": "planned_not_executed" },
        "authority": { "const": "bounded_source_evidence_only" }
      }
    },
    "observation": {
      "type": "object",
      "required": ["level", "message"],
      "additionalProperties": false,
      "properties": {
        "level": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": { "type": ["integer", "number", "boolean", "string", "null"] }
    }
  }
}
