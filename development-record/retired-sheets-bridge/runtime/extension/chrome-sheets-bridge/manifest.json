{
  "manifest_version": 3,
  "name": "Chrome Sheets Bridge",
  "version": "0.1.1",
  "description": "Broker-backed Google Sheets inspection bridge for local spreadsheet review workflows.",
  "key": "",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Sheets Bridge"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/spreadsheets/d/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://docs.google.com/spreadsheets/*",
    "https://*.run.app/*",
    "http://localhost/*"
  ],
  "oauth2": {
    "client_id": "862894425240-1r90upabo0gb42t41p7gj36dp1r37j24.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "permissions": ["activeTab", "identity", "identity.email", "nativeMessaging"]
}
