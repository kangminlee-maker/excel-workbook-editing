{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://day1company.local/sheets-bridge/native-message.schema.json",
  "title": "Chrome Sheets Bridge Native Message",
  "description": "Stable Native Messaging envelope for extension-host requests, results, and errors.",
  "oneOf": [
    {
      "title": "Request message",
      "type": "object",
      "required": ["protocol_version", "request_id", "type", "payload"],
      "additionalProperties": false,
      "properties": {
        "protocol_version": { "const": "1.0" },
        "request_id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["inspect.snapshot", "review.generate", "plan.generate", "apply.record"]
        },
        "payload": { "type": "object" }
      }
    },
    {
      "title": "Result message",
      "type": "object",
      "required": ["protocol_version", "request_id", "type", "ok", "payload"],
      "additionalProperties": false,
      "properties": {
        "protocol_version": { "const": "1.0" },
        "request_id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["review.result", "plan.result", "apply.result"]
        },
        "ok": { "const": true },
        "payload": { "type": "object" }
      }
    },
    {
      "title": "Error message",
      "type": "object",
      "required": ["protocol_version", "request_id", "type", "ok", "error"],
      "additionalProperties": false,
      "properties": {
        "protocol_version": { "const": "1.0" },
        "request_id": { "type": "string", "minLength": 1 },
        "type": { "const": "error" },
        "ok": { "const": false },
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "additionalProperties": false,
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  ]
}
