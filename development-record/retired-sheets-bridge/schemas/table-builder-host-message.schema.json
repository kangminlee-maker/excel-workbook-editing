{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://day1company.local/sheets-bridge/table-builder-host-message.schema.json",
  "title": "Table Builder Host Adapter Message",
  "oneOf": [
    {
      "type": "object",
      "required": ["schema_version", "message_kind", "intent"],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "const": "1.0" },
        "message_kind": { "const": "table_build_intent_submit_v1" },
        "intent": {
          "type": "object",
          "required": ["schema_version", "intent_kind", "output_canvas", "llm_prompt"],
          "additionalProperties": true,
          "properties": {
            "schema_version": { "const": "1.0" },
            "intent_kind": { "const": "table_build_intent_v1" },
            "output_canvas": { "type": "array", "minItems": 1 },
            "llm_prompt": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "type": "object",
      "required": [
        "schema_version",
        "message_kind",
        "intent_id",
        "intent_path",
        "package",
        "next_prompt"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "const": "1.0" },
        "message_kind": { "const": "table_build_intent_saved_v1" },
        "intent_id": { "type": "string", "minLength": 1 },
        "intent_path": { "type": "string", "minLength": 1 },
        "package": { "type": "object" },
        "next_prompt": { "type": "string", "minLength": 1 }
      }
    }
  ]
}
