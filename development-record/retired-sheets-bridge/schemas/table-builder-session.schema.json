{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://day1company.local/sheets-bridge/table-builder-session.schema.json",
  "title": "TableBuilderSession",
  "type": "object",
  "required": [
    "schema_version",
    "session_kind",
    "session_id",
    "created_at",
    "status",
    "intent",
    "artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0" },
    "session_kind": { "const": "table_builder_session_v1" },
    "session_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "intent": {
      "type": "object",
      "required": [
        "schema_version",
        "intent_kind",
        "intent_id",
        "created_at",
        "source",
        "source_package",
        "artifact_type",
        "output_canvas",
        "llm_prompt",
        "output",
        "review_state"
      ],
      "properties": {
        "schema_version": { "const": "1.0" },
        "intent_kind": { "const": "table_build_intent_v1" },
        "intent_id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "minLength": 1 },
        "source": { "type": "object" },
        "source_package": { "type": "object" },
        "artifact_type": { "type": "string", "enum": ["google_sheets", "excel_workbook"] },
        "output_canvas": { "type": "array", "minItems": 1 },
        "llm_prompt": { "type": "string", "minLength": 1 },
        "source_hints": { "type": "object" },
        "fields": { "type": "object" },
        "formula": { "type": "object" },
        "output": {
          "type": "object",
          "required": ["creation_mode"],
          "properties": {
            "creation_mode": { "type": "string", "enum": ["sheet", "copy"] }
          },
          "additionalProperties": true
        },
        "review_state": { "type": "object" }
      },
      "additionalProperties": false
    },
    "plan": { "type": ["object", "null"] },
    "artifacts": { "type": "object" }
  }
}
